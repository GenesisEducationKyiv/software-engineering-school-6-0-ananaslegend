# HTTP server
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_SHUTDOWN_TIMEOUT=15s

# PostgreSQL
DATABASE_URL=postgres://postgres:pass@localhost:5432/postgres?sslmode=disable
DB_MAX_CONNS=10

# Application
APP_BASE_URL=http://localhost:8080
CONFIRM_TOKEN_TTL=24h

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# SMTP (leave SMTP_HOST empty to use StubMailer / console logging)
# Dev: brew install mailpit && mailpit  →  web UI at http://localhost:8025, SMTP at localhost:1025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS_POLICY=none
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Docker overrides (values below match docker-compose.yml defaults — uncomment to override)
# DATABASE_URL=postgres://postgres:pass@postgres:5432/postgres?sslmode=disable
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_TLS_POLICY=none

# GitHub (optional — without token: 60 req/h rate limit; with token: 5000 req/h)
# GITHUB_TOKEN=

# Scanner / Notifier
SCANNER_INTERVAL=5m
NOTIFIER_INTERVAL=30s
